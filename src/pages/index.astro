---
import Layout from "../layouts/Layout.astro";
import LifeBridgeChat from "../components/LifeBridgeChat";

const calendlyUrl = "https://calendly.com/lifebridgeguidance/30min";
const contactEmail = "hi@lifebridgeguidance.com";
---

<Layout title="LifeBridge Guidance - Family Loss Concierge Services">
	<!-- ==================== HEADER ==================== -->
	<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200/50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex items-center justify-between h-16 md:h-20">
<a href="/" class="flex flex-col items-start group">
	<svg class="w-24 h-18 text-[#4a6b8a] group-hover:text-[#3a5570] transition-colors -mb-10" viewBox="0 0 1536 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
